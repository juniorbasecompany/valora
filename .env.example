# O Docker Compose usa `POSTGRES_PASSWORD` para o PostgreSQL de desenvolvimento.
# O backend lê a mesma variável (ver `backend/src/valora_backend/config.py`).
POSTGRES_PASSWORD=

# Backend: validação do Google ID token recebida do frontend.
GOOGLE_CLIENT_ID=

# Backend: assinatura do JWT da aplicação.
APP_JWT_SECRET=

# Frontend: Client ID usado pelo Google Identity Services na UI.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Frontend: URL base do backend FastAPI.
NEXT_PUBLIC_API_URL=http://localhost:8000
