# O Docker Compose usa `POSTGRES_PASSWORD` para o PostgreSQL de desenvolvimento.
# O backend lê este arquivo (ver `backend/src/valora_backend/config.py`).
# Em plataformas como Railway, pode usar só `DATABASE_URL` (referência ao plugin Postgres).
POSTGRES_PASSWORD=

# Opcional em PaaS: substitui host/porta/user/db/password (ex.: URL injetada pelo Railway).
# DATABASE_URL=
#
# No Railway também podes referenciar do plugin Postgres (sem DATABASE_URL): PGHOST, PGPORT,
# PGUSER, PGPASSWORD, PGDATABASE (o backend lê estes nomes além de POSTGRES_*).

# Backend: validação do Google ID token recebida do frontend.
GOOGLE_CLIENT_ID=

# Backend: assinatura do JWT da aplicação.
APP_JWT_SECRET=

# Opcional: dias de validade do JWT quando o usuário marca "permanecer logado" (padrão 30).
# APP_JWT_REMEMBER_ME_EXPIRATION_DAYS=30

